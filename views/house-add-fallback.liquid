{% layout "layouts/main-layout.liquid" %}

{% block content %}    
    <h2>Woning bewaren: {{ house.current_house }}</h2>
    
    <form action="/favorieten/opslaan" method="POST">
    <input type="hidden" name="house_id" value="{{ house.id }}">
    <input type="hidden" name="redirect_back" value="/huizen/{{ house.city | downcase }}/{{ house.street | downcase }}/{{ house.slug }}">
    
    <section>
        {% for list in lists %}
        <label style="display: block; margin-bottom: 0.5rem;">
            <input type="radio" name="list_id" value="{{ list.id }}" required>
            <strong>{{ list.title }}</strong> ({{ list.houses.size }})
        </label>
        {% else %}
        <p>Je hebt nog geen lijstjes aangemaakt.</p>
        {% endfor %}
    </section>

    <button type="submit" class="btn-submit-save">In lijst opslaan</button>
    </form>
{% endblock %}