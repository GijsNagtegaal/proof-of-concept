{%- assign src = imagesrc.id | default: imagesrc -%}

{% if format == "svg" %}
<img src="{{ src }}"
    width="{{ width }}"
    height="{{ height }}"
    fetchpriority="{{ fetch | default: 'auto' }}"
    loading="{{ loading | default: 'lazy' }}"
    decoding="async"
    alt="{{ alt_text | default: 'Icon of logo' }}">

{% elsif src contains '/assets/images' %}
<picture class="funda-skeleton-wrapper {{ class }}">
    <source srcset="{{ src }}?format=avif&quality=80" type="image/avif">
    <source srcset="{{ src }}?format=webp&quality=80" type="image/webp">
    <img src="{{ src }}?width={{ width }}&height={{ height }}&quality=50"
    width="{{ width }}"
    height="{{ height }}"
    fetchpriority="{{ fetch | default: 'auto' }}"
    loading="{{ loading | default: 'eager' }}"
    decoding="async"
    alt="{{ alt_text | default: 'Afbeelding' }}">
</picture>

{% else %}
{%- assign base = "https://fdnd-agency.directus.app/assets/" | append: src -%}
<picture class="funda-skeleton-wrapper {{ class }}">
    <source type="image/avif"
    srcset="{{ base }}?format=avif&width={{ width }}&quality=80&fit=cover {{ width }}w,
            {{ base }}?format=avif&width={{ width | times: 2 }}&quality=75&fit=cover {{ width | times: 2 }}w"
    sizes="{{ sizes | default: '100vw' }}">
    <source type="image/webp"
    srcset="{{ base }}?format=webp&width={{ width }}&quality=80&fit=cover {{ width }}w,
            {{ base }}?format=webp&width={{ width | times: 2 }}&quality=75&fit=cover {{ width | times: 2 }}w"
    sizes="{{ sizes | default: '100vw' }}">
    <img src="{{ base }}?format=jpeg&width={{ width }}&height={{ height }}&quality=60&fit=cover"
    width="{{ width }}"
    height="{{ height }}"
    fetchpriority="{{ fetch | default: 'auto' }}"
    loading="{{ loading | default: 'lazy' }}"
    decoding="async"
    alt="{{ alt_text | default: 'Afbeelding' }}">
</picture>
{% endif %}