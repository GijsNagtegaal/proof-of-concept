{%- assign default_width = width | default: "320" -%}
{%- assign default_height = height | default: "200" -%}

{% if imagesrc contains '/assets/images' and format != "svg" %}

    <picture class="funda-skeleton-wrapper {{ class }}" >
        <source srcset="{{ imagesrc }}.avif?width={{ default_width }}&height={{ default_height }}&quality=80" type="image/avif" width="{{ default_width }}" height="{{ default_height }}">
        <source srcset="{{ imagesrc }}.webp?width={{ default_width }}&height={{ default_height }}&quality=80" type="image/webp" width="{{ default_width }}" height="{{ default_height }}">
        <img src="{{ imagesrc }}?width={{ default_width }}&height={{ default_height }}&quality=50" 
            width="{{ default_width }}" 
            height="{{ default_height }}" 
            fetchpriority="{{ fetch | default: 'auto' }}" 
            loading="{{ loading | default: 'eager' }}" 
            decoding="async"
            alt="{{ alt_text | default: 'Afbeelding' }}">
    </picture>

{% elsif format == "svg" %}

    <img src="{{ imagesrc }}" 
        width="{{ default_width }}" 
        height="{{ default_height }}" 
        fetchpriority="{{ fetch | default: 'auto' }}" 
        loading="{{ loading | default: 'eager' }}" 
        decoding="async"
        alt="{{ alt_text | default: 'Icon of logo' }}">

{% else %}

    <picture class="funda-skeleton-wrapper {{ custom_class }}" >
        <source srcset="https://fdnd-agency.directus.app/assets/{{ imagesrc }}?format=avif&quality=80&width={{ default_width }}&height={{ default_height }}&fit=cover" 
            type="image/avif"
            width="{{ default_width }}" 
            height="{{ default_height }}">
                
        <source srcset="https://fdnd-agency.directus.app/assets/{{ imagesrc }}?format=webp&quality=80&width={{ default_width }}&height={{ default_height }}&fit=cover" 
            type="image/webp"
            width="{{ default_width }}" 
            height="{{ default_height }}">
                
        <img src="https://fdnd-agency.directus.app/assets/{{ imagesrc }}?quality=60&width={{ default_width }}&height={{ default_height }}&fit=cover" 
            width="{{ default_width }}" 
            height="{{ default_height }}" 
            fetchpriority="{{ fetch | default: 'auto' }}" 
            loading="{{ loading | default: 'eager' }}" 
            decoding="async"
            alt="{{ alt_text }}">
    </picture>
    
{% endif %}