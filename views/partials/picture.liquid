{%- assign default_width = width | default: "320" -%}
{%- assign default_height = height | default: "200" -%}

{%- assign final_image_src = imagesrc.id | default: imagesrc -%}

{% if final_image_src contains '/assets/images' and format != "svg" %}

    <picture class="funda-skeleton-wrapper {{ class }}" >
        <source srcset="{{ final_image_src }}.avif&quality=80" type="image/avif" width="{{ default_width }}" height="{{ default_height }}">
        <source srcset="{{ final_image_src }}.webp&quality=80" type="image/webp" width="{{ default_width }}" height="{{ default_height }}">
        <img src="{{ final_image_src }}?width={{ default_width }}&height={{ default_height }}&quality=50" 
            width="{{ default_width }}" 
            height="{{ default_height }}" 
            fetchpriority="{{ fetch | default: 'auto' }}" 
            loading="{{ loading | default: 'eager' }}" 
            decoding="async"
            alt="{{ alt_text | default: 'Afbeelding' }}">
    </picture>

{% elsif format == "svg" %}

    <img src="{{ final_image_src }}" 
        width="{{ default_width }}" 
        height="{{ default_height }}" 
        fetchpriority="{{ fetch | default: 'auto' }}" 
        loading="{{ loading | default: 'eager' }}" 
        decoding="async"
        alt="{{ alt_text | default: 'Icon of logo' }}">

{% else %}

    <picture class="funda-skeleton-wrapper {{ custom_class }}" >
        <source srcset="https://fdnd-agency.directus.app/assets/{{ final_image_src }}?format=avif&quality=80&fit=cover" 
            type="image/avif"
            width="{{ default_width }}" 
            height="{{ default_height }}">
                
        <source srcset="https://fdnd-agency.directus.app/assets/{{ final_image_src }}?format=webp&quality=80&fit=cover" 
            type="image/webp"
            width="{{ default_width }}" 
            height="{{ default_height }}">
                
        <img src="https://fdnd-agency.directus.app/assets/{{ final_image_src }}?quality=60&width={{ default_width }}&height={{ default_height }}&fit=cover" 
            width="{{ default_width }}" 
            height="{{ default_height }}" 
            fetchpriority="{{ fetch | default: 'auto' }}" 
            loading="{{ loading | default: 'eager' }}" 
            decoding="async"
            alt="{{ alt_text }}">
    </picture>
    
{% endif %}