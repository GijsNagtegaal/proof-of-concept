                    <path fill-rule="evenodd" clip-rule="evenodd" d="M21.5 2.75C21.5 2.33579 21.1642 2 20.75 2H3.25C2.83579 2 2.5 2.33579 2.5 2.75V21.25C2.5 21.6642 2.83579 22 3.25 22H20.75C21.1642 22 21.5 21.6642 21.5 21.25V2.75ZM4 7.25H10.5V9.75C10.5 10.1642 10.8358 10.5 11.25 10.5H15V20.5H4V7.25ZM16.5 9.75C16.5 9.33579 16.1642 9 15.75 9H12V6.5C12 6.08579 11.6642 5.75 11.25 5.75H4V3.5H20V20.5H16.5V9.75Z" fill="#4D4D4D"/>
