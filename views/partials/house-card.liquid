{% assign house_href = "/huizen/" | append: house.city_clean | append: "/" | append: house.street_clean | append: "/" | append: house.slug %}
{% assign slug_key = house.slug | prepend: "|" | append: "|" %}
{% assign vt_name = house.slug %}
{% assign seen_vt_slugs = seen_vt_slugs | append: slug_key %}

<article class="house-card">
    <section class="house-image-wrapper">
        {% if house.poster_image %}
            {% render 'partials/image-link.liquid',
                href: house_href,
                imagesrc: house.poster_image,
                vt_name: vt_name,
                fetch: "auto",
                width: "800",
                height: "800",
                custom_class: "poster gallery-item",
            %}
        {% endif %}
    </section>
    <section class="content-card">
        <a href="{{ house_href }}">{{ house.street }} {{ house.house_nr }}{{ house.nr_addition }}</a>
        <p>{{ house.postal_code }} {{ house.city }}</p>
        <p class="house-price breathingspace">
            {% if house.price %}
            &euro; {{ house.price }} k.k.
            {% else %}
            Prijs op aanvraag
            {% endif %}
        </p>

        <section class="house-specs">
            <p>
