            </p>
            <p>
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path fill-rule="evenodd" clip-rule="evenodd" d="M11.8376 6.44552L8.41164 12.9768L11.9275 13.7908L12.1735 17.7268L15.829 11.0404L12.0738 10.2253L11.8376 6.44552ZM13.0625 1.99704L13.5002 9.00001L16.6369 9.68085C17.4472 9.85673 17.7847 10.5901 17.3868 11.3181L11.4775 22.1269C11.2129 22.6109 10.9723 22.5536 10.9379 22.003L10.5002 15L7.64332 14.3386C6.83705 14.1519 6.49345 13.4045 6.87879 12.6699L12.5368 1.88333C12.7924 1.39617 13.0281 1.4464 13.0625 1.99704Z" fill="#4D4D4D"/>
