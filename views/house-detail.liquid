                    <path fill-rule="evenodd" clip-rule="evenodd" d="M11.7506 10.0349H19.2506C19.4495 10.0349 19.6403 10.1139 19.7809 10.2546C19.9216 10.3952 20.0006 10.586 20.0006 10.7849V17.2849C20.0006 17.4838 19.9216 17.6746 19.7809 17.8152C19.6403 17.9559 19.4495 18.0349 19.2506 18.0349H11.7506C11.5517 18.0349 11.3609 17.9559 11.2203 17.8152C11.0796 17.6746 11.0006 17.4838 11.0006 17.2849V10.7849C11.0006 10.586 11.0796 10.3952 11.2203 10.2546C11.3609 10.1139 11.5517 10.0349 11.7506 10.0349ZM18.5006 11.5349H12.5006V16.5349H18.5006V11.5349Z" fill="#0071B3"/>
                    <path fill-rule="evenodd" clip-rule="evenodd" d="M11.7506 0.0349126H19.2506C19.4495 0.0349126 19.6403 0.11393 19.7809 0.254582C19.9216 0.395235 20.0006 0.586 20.0006 0.784913V7.28491C20.0006 7.48382 19.9216 7.67459 19.7809 7.81524C19.6403 7.95589 19.4495 8.03491 19.2506 8.03491H11.7506C11.6508 8.03493 11.5521 8.01505 11.4601 7.97642C11.3681 7.9378 11.2847 7.88121 11.2149 7.80997C11.1451 7.73873 11.0901 7.65427 11.0533 7.56153C11.0165 7.4688 10.9986 7.36966 11.0006 7.26991V0.769912C11.0045 0.573611 11.0853 0.386677 11.2255 0.249253C11.3657 0.111829 11.5543 0.0348733 11.7506 0.0349126ZM18.5006 1.53491H12.5006V6.53491H18.5006V1.53491Z" fill="#0071B3"/>
                </svg>
                </figure>
                <figcaption>
                    Alle media
                </figcaption>
            </a>
        </section>

        <section class="max-width">
            <h1>{{ current_house }}</h1>
        </section>

{% endblock %}